APP_NAME=php-llm-benchy
APP_ENV=local
APP_DEBUG=true
APP_URL=http://127.0.0.1:8080

DEFAULT_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_NUM_CTX=65536

DEFAULT_SEED=4242
DEFAULT_RUNS_PER_BENCHMARK=1
DATABASE_PATH=storage/benchy.sqlite
EXPORT_PATH=storage/exports
SANDBOX_PATH=storage/sandbox

# Optional future-provider credentials
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=