{
    "name": "carmelosantana/php-llm-benchy",
    "description": "LLM benchmarking.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "ext-json": "*",
        "ext-pdo_sqlite": "*",
        "carmelosantana/php-agents": "^0.12.1",
        "symfony/process": "^7.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "CarmeloSantana\\PHPLLMBenchy\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/serve"
    ],
    "scripts": {
        "test": "pest",
        "analyse": "phpstan analyse --memory-limit=512M",
        "serve": "php -S 127.0.0.1:8080 -t public public/index.php"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}